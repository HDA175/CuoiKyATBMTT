</div>

<div class="to-top">
    <a href="#top"><i class="fa-solid fa-arrow-up"></i></a>
</div>

@section Scripts {
    <script src="~/Scripts/jquery.signalR-2.4.3.min.js"></script>
    <script src="/signalr/hubs"></script>

    <script>
        $(function () {
            var chat = $.connection.chatHub;
            var isConnected = false;
            var isChatOpen = false;
            var pendingQuestion = null;

            // Mở popup chat
            $('#openChatBtn').click(openChat);

            // Đóng popup chat
            $('#closeChatBtn').click(closeChat);
            $('#chatOverlay').click(closeChat);

            // Đóng khi nhấn ESC
            $(document).keydown(function (e) {
                if (e.keyCode === 27 && isChatOpen) {
                    closeChat();
                }
            });

            function openChat() {
                $('#chatPopup').show();
                $('#chatOverlay').show();
                isChatOpen = true;
                $('body').css('overflow', 'hidden');
                $('#chatWindow').scrollTop($('#chatWindow')[0].scrollHeight);

                if (!$('#messageInput').prop('disabled')) {
                    $('#messageInput').focus();
                }
            }

            function closeChat() {
                $('#chatPopup').hide();
                $('#chatOverlay').hide();
                isChatOpen = false;
                $('body').css('overflow', 'auto');
            }

            // Hiển thị thông báo
            function showNotification(message) {
                var notification = $('<div class="notification">' + message + '</div>');
                $('body').append(notification);

                setTimeout(function () {
                    notification.fadeOut(300, function () {
                        $(this).remove();
                    });
                }, 5000);
            }

            // Thêm tin nhắn vào khung chat
            function addMessage(content, side) {
                var messageClass = side === 'left' ? 'message-left' : 'message-right';
                var html = '<div class="' + messageClass + '">' +
                    $('<div/>').text(content).html() +
                    '</div>';
                $('#chatWindow').append(html);
                $('#chatWindow').scrollTop($('#chatWindow')[0].scrollHeight);
            }

            // Thêm tin nhắn hệ thống
            function addSystemMessage(message) {
                var html = '<div class="message-center">' +
                    $('<div/>').text(message).html() +
                    '</div>';
                $('#chatWindow').append(html);
                $('#chatWindow').scrollTop($('#chatWindow')[0].scrollHeight);
            }

            // Hiển thị/ẩn đề xuất
            function toggleSuggestions(show) {
                if (show) {
                    $('#suggestionsBox').show();
                } else {
                    $('#suggestionsBox').hide();
                }
            }

            // Xử lý khi click vào câu đề xuất
            $(document).on('click', '.suggestion-btn', function () {
                var question = $(this).data('question');

                if ($('#messageInput').prop('disabled')) {
                    // Chưa kết nối, yêu cầu hỗ trợ trước
                    pendingQuestion = question;
                    chat.server.requestSupport();
                    $('#requestButton').prop('disabled', true)
                        .html('<i class="fas fa-spinner fa-spin"></i> Đang chờ...');
                } else {
                    // Đã kết nối, gửi ngay
                    sendMessage(question);
                }
            });

            // Gửi tin nhắn
            function sendMessage(message) {
                if (!message.trim()) return;

                addMessage('Bạn: ' + message, 'right');
                chat.server.sendMessage(message);
                $('#messageInput').val('').focus();
            }

            // Nhận tin nhắn từ server
            chat.client.receiveMessage = function (sender, message) {
                addMessage(sender + ': ' + message, 'left');
                if (!isChatOpen) {
                    showNotification('💬 Có tin nhắn mới từ nhân viên');
                }
            };

            chat.client.receiveSystemMessage = function (message) {
                addSystemMessage(message);

                if (message.includes("kết nối")) {
                    // Đã kết nối với nhân viên
                    $('#messageInput').prop('disabled', false);
                    $('#sendButton').prop('disabled', false);
                    $('#requestButton').prop('disabled', true)
                        .html('<i class="fas fa-user-check"></i> Đã kết nối');
                    toggleSuggestions(false);

                    // Gửi câu hỏi đang chờ
                    if (pendingQuestion) {
                        setTimeout(function () {
                            sendMessage(pendingQuestion);
                            pendingQuestion = null;
                        }, 1000);
                    }

                    if (isChatOpen) {
                        $('#messageInput').focus();
                    }

                    if (!isChatOpen) {
                        showNotification('✅ Nhân viên đã kết nối với bạn');
                    }
                } else if (message.includes("đóng")) {
                    // Kết thúc chat
                    $('#messageInput').prop('disabled', true);
                    $('#sendButton').prop('disabled', true);
                    $('#requestButton').prop('disabled', false)
                        .html('<i class="fas fa-hand-paper"></i> Yêu cầu hỗ trợ');
                    toggleSuggestions(true);
                    pendingQuestion = null;
                }
            };

            // Kết nối SignalR
            $.connection.hub.start().done(function () {
                isConnected = true;
                $('#statusText').text('Đã kết nối máy chủ').css('color', '#4CAF50');

                // Xử lý yêu cầu hỗ trợ
                $('#requestButton').click(function () {
                    chat.server.requestSupport();
                    addSystemMessage("🕒 Đang kết nối với nhân viên hỗ trợ...");
                    $(this).prop('disabled', true)
                        .html('<i class="fas fa-spinner fa-spin"></i> Đang chờ...');
                });

                // Xử lý gửi tin nhắn
                $('#sendButton').click(function () {
                    var msg = $('#messageInput').val().trim();
                    sendMessage(msg);
                });

                // Enter để gửi
                $('#messageInput').keypress(function (e) {
                    if (e.which === 13) {
                        $('#sendButton').click();
                    }
                });

                // Hiển thị đề xuất ban đầu
                toggleSuggestions(true);

            }).fail(function (err) {
                console.error('Kết nối thất bại:', err);
                $('#statusText').text('Lỗi kết nối').css('color', '#F44336');
                addSystemMessage("❌ Không thể kết nối đến máy chủ chat");
            });
        });
    </script>
}