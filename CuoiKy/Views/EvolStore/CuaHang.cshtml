                        <a href="@Url.Action("CuaHang", "EvolStore", new { size = "XL" })"
                           class="category-link @(ViewBag.SelectedSize == "XL" ? "active" : "")">
                            <i class="fas fa-tshirt" style="color:#f39c12;"></i>Size XL
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Nút xóa bộ lọc -->
            @if (!string.IsNullOrEmpty(selectedLoai) || !string.IsNullOrEmpty(selectedChatLieu) || !string.IsNullOrEmpty(selectedMucGia) || !string.IsNullOrEmpty(ViewBag.SelectedThuongHieu) || !string.IsNullOrEmpty(ViewBag.SelectedSize))
            {
                <div class="category-section">
                    <a href="@Url.Action("CuaHang", "EvolStore")" class="category-link" style="background:#e74c3c; color:white; justify-content:center;">
                        <i class="fas fa-times"></i> Xóa bộ lọc
                    </a>
                </div>
            }
        </div>

        <!-- PRODUCTS SECTION -->
        <section class="products-section">
            <h2 class="section-title">CỬA HÀNG SẢN PHẨM</h2>

            @if (!string.IsNullOrEmpty(selectedLoai) || !string.IsNullOrEmpty(selectedChatLieu) || !string.IsNullOrEmpty(selectedMucGia) || !string.IsNullOrEmpty(searchTerm) || !string.IsNullOrEmpty(ViewBag.SelectedThuongHieu) || !string.IsNullOrEmpty(ViewBag.SelectedSize))
            {
                <div class="product-count">
                    Tìm thấy <strong>@Model.Count</strong> sản phẩm
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <span>cho từ khóa "<strong>@searchTerm</strong>"</span>
                    }
                    @if (!string.IsNullOrEmpty(selectedLoai))
                    {
                        <span>
                            trong danh mục "<strong>
                                @switch (selectedLoai)
                                {
                                    case "ao":<text>Áo</text>; break;
                                case "ao-khoac": <text>Áo khoác</text>; break;
                            case "quan": <text>Quần</text>; break;
                        case "vay-dam": <text>Váy & Đầm</text>; break;
                    case "giay-dep": <text>Giày dép</text>; break;
                case "phu-kien": <text>Phụ kiện</text>; break;
            case "balo-tui-xach": <text>Balo & Túi xách</text>; break;
        case "do-the-thao": <text>Đồ thể thao</text>; break;
    case "do-ngu": <text>Đồ ngủ</text>; break;
case "do-boi": <text>Đồ bơi</text>; break;
default: <text>@selectedLoai</text>; break;
}
                            </strong>"
                        </span>
                    }
                </div>
            }

            @if (Model == null || Model.Count == 0)
            {
                <div class="no-products">
                    <i class="fas fa-box-open"></i>
                    <h3>KHÔNG CÓ SẢN PHẨM NÀO</h3>
                    <p>Không tìm thấy sản phẩm phù hợp với bộ lọc của bạn.</p>
                    <a href="@Url.Action("CuaHang", "EvolStore")" class="add-to-cart-btn" style="width:auto; margin-top:20px; display:inline-block;">
                        <i class="fas fa-undo"></i> Xem tất cả sản phẩm
                    </a>
                </div>
            }
            else
            {
        <div class="products-grid">
            @foreach (var product in Model)
            {
                // Tính toán giá gốc và giảm giá ngay trong view
                decimal phanTramGiam = 0;
                decimal giaGoc = product.Gia;
                bool coGiamGia = false;

                // Kiểm tra nếu sản phẩm có giảm giá (cần có thuộc tính GiamGias trong model)
                if (product.GiamGias != null && product.GiamGias.Any())
                {
                    var giamGiaHienTai = product.GiamGias
                        .Where(g => g.NgayBatDau <= DateTime.Now &&
                                   (g.NgayKetThuc == null || g.NgayKetThuc >= DateTime.Now))
                        .OrderByDescending(g => g.PhanTramGiam)
                        .FirstOrDefault();

                    if (giamGiaHienTai != null && giamGiaHienTai.PhanTramGiam > 0)
                    {
                        phanTramGiam = giamGiaHienTai.PhanTramGiam * 100;
                        giaGoc = Math.Round(product.Gia / (1 - giamGiaHienTai.PhanTramGiam), 0);
                        coGiamGia = true;
                    }
                }

                <div class="product-card">
                    <a href="@Url.Action("ChiTietSanPham", "EvolStore", new { id = product.MaSP })" class="product-card-link">
                        @if (product.SoLuongTon <= 0)
                        {
                            <div class="out-of-stock">HẾT HÀNG</div>
                        }

                        @if (coGiamGia)
                        {
                            <div class="discount-badge">
                                -@phanTramGiam.ToString("0")%
                            </div>
                        }

                        <img src="~/Images/@(product.MaSP + "a.jpg")"
                             alt="@product.TenSP"
                             class="product-image" />

                        <div class="product-info">
                            <h3 class="product-name">@product.TenSP</h3>

                            <div class="product-price-container">
                                @if (coGiamGia)
                                {
                                    <div class="original-price">
                                        @giaGoc.ToString("N0") ₫
                                    </div>
                                    <div class="discounted-price">
                                        @product.Gia.ToString("N0") ₫
                                    </div>
                                }
                                else
                                {
                                    <div class="discounted-price" style="margin-top: 10px;">
                                        @product.Gia.ToString("N0") ₫
                                    </div>
                                }
                            </div>

                            
                        </div>
                    </a>

                    @if (product.SoLuongTon > 0)
                    {
                        <button class="add-to-cart-btn" onclick="openProductModal(@product.MaSP, '@product.TenSP.Replace("'", "\\'")')">
                            <i class="fas fa-shopping-cart"></i> THÊM VÀO GIỎ
                        </button>
                    }
                    else
                    {
                        <button class="add-to-cart-btn" disabled>
                            <i class="fas fa-times"></i> HẾT HÀNG
                        </button>
                    }
                </div>
            }
        </div>
            }
        </section>
    </div>

    <!-- FOOTER -->
    @Html.Action("FooterPartial", "EvolStore")

