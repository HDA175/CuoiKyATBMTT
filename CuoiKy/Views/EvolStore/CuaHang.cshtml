        </div>
        <div class="cart-summary" id="cartSummary" style="display: none;">
            <div class="summary-row">
                <span>Tạm tính:</span>
                <span id="subtotal">0 ₫</span>
            </div>

            <div class="summary-row">
                <span>Giảm giá:</span>
                <span>-0 ₫</span>
            </div>
            <div class="summary-row summary-total">
                <span>Tổng cộng:</span>
                <span id="total">30,000 ₫</span>
            </div>

            <button class="checkout-btn" onclick="checkout()">
                <i class="fas fa-credit-card"></i> ĐẶT MUA
            </button>

            <a href="@Url.Action("CuaHang", "EvolStore")" class="continue-shopping">
                <i class="fas fa-arrow-left"></i> TIẾP TỤC MUA SẮM
            </a>
        </div>
    </div>

    <script>
        // ===========================
        // BIẾN TOÀN CỤC
        // ===========================
        let selectedProductId = null;
        let selectedProductName = '';
        let cart = JSON.parse(localStorage.getItem('evolstore_cart')) || [];

        // ===========================
        // KHỞI TẠO TRANG
        // ===========================
        document.addEventListener('DOMContentLoaded', function() {
            updateCartCount();
            loadCartItems();
            initModal();

            // Header co lại khi cuộn
            window.addEventListener('scroll', function () {
                const headerTop = document.getElementById('headerTop');
                if (window.scrollY > 50) headerTop.classList.add('scrolled');
                else headerTop.classList.remove('scrolled');
            });

            // Tự động focus vào ô search nếu có search term
            @if (!string.IsNullOrEmpty(searchTerm))
            {
                <text>
                document.getElementById('searchBox').classList.add('active');
                document.getElementById('searchInput').focus();
                </text>
            }
        });

        // ===========================
        // TÌM KIẾM
        // ===========================
        const searchBox = document.getElementById('searchBox');
        const searchInput = document.getElementById('searchInput');

        searchBox.addEventListener('click', function (e) {
            e.stopPropagation();
            searchBox.classList.add('active');
            searchInput.focus();
        });

        document.addEventListener('click', function (e) {
            if (!searchBox.contains(e.target) && searchInput.value.trim() === '') {
                searchBox.classList.remove('active');
            }
        });

        searchInput.addEventListener('input', function () {
            if (this.value !== '') searchBox.classList.add('active');
        });

        searchInput.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                const q = this.value.trim();
                if (q) {
                    window.location.href = '@Url.Action("CuaHang", "EvolStore")?search=' + encodeURIComponent(q);
                }
            }
        });

        // ===========================
        // MODAL SẢN PHẨM
        // ===========================
        function initModal() {
            // Xử lý chọn size
            document.querySelectorAll('.size-option').forEach(option => {
                option.addEventListener('click', function () {
                    document.querySelectorAll('.size-option').forEach(opt => {
                        opt.style.borderColor = '#ddd';
                        opt.style.background = 'white';
                        opt.style.color = 'inherit';
                    });
                    this.style.borderColor = '#ff6b9d';
                    this.style.background = '#fff5f8';
                    this.style.color = '#ff6b9d';
                });
            });

            // Xử lý chọn màu
            document.querySelectorAll('.color-option').forEach(option => {
                option.addEventListener('click', function () {
                    document.querySelectorAll('.color-option').forEach(opt => {
                        opt.style.borderColor = '#ddd';
                        opt.style.background = 'white';
                        opt.querySelector('span:last-child').style.color = 'inherit';
                        opt.querySelector('span:last-child').style.fontWeight = 'normal';
                    });
                    this.style.borderColor = '#ff6b9d';
                    this.style.background = '#fff5f8';
                    this.querySelector('span:last-child').style.color = '#ff6b9d';
                    this.querySelector('span:last-child').style.fontWeight = 'bold';
                });
            });

            // Kích hoạt style cho option mặc định
            document.querySelector('.size-option input:checked').closest('.size-option').click();
            document.querySelector('.color-option input:checked').closest('.color-option').click();
        }

        function openProductModal(productId, productName) {
            selectedProductId = productId;
            selectedProductName = productName;
            document.getElementById('modalProductName').textContent = productName;
            document.getElementById('productModal').style.display = 'block';

            // Reset quantity về 1 mỗi khi mở modal
            document.getElementById('modalQuantity').value = 1;
        }

        function closeModal() {
            document.getElementById('productModal').style.display = 'none';
            selectedProductId = null;
            selectedProductName = '';
        }

        function increaseModalQuantity() {
            const input = document.getElementById('modalQuantity');
            if (parseInt(input.value) < 10) {
                input.value = parseInt(input.value) + 1;
            }
        }

        function decreaseModalQuantity() {
            const input = document.getElementById('modalQuantity');
            if (parseInt(input.value) > 1) {
                input.value = parseInt(input.value) - 1;
            }
        }

        function confirmAddToCart() {
            if (!selectedProductId) return;

            const size = document.querySelector('input[name="size"]:checked').value;
            const color = document.querySelector('input[name="color"]:checked').value;
            const quantity = parseInt(document.getElementById('modalQuantity').value);

            addToCart(selectedProductId, selectedProductName, quantity, size, color);
            closeModal();
        }

        function addToCart(productId, productName, quantity, size, color) {
            // Kiểm tra sản phẩm đã có trong giỏ chưa
            const existingItemIndex = cart.findIndex(item =>
                item.id == productId && item.size === size && item.color === color
            );

            if (existingItemIndex > -1) {
                // Cập nhật số lượng nếu đã có
                cart[existingItemIndex].quantity += quantity;
            } else {
                // Thêm mới sản phẩm
                const newItem = {
                    id: productId,
                    name: productName,
                    price: getProductPrice(productId),
                    quantity: quantity,
                    size: size,
                    color: color,
                    image: '/Images/' + productId + 'a.jpg'
                };
                cart.push(newItem);
            }

            saveCart();
            updateCartCount();
            loadCartItems();
            showNotification('Đã thêm vào giỏ hàng!');
        }

        function updateQuantity(productId, size, color, change) {
            const itemIndex = cart.findIndex(item =>
                item.id == productId && item.size === size && item.color === color
            );

            if (itemIndex > -1) {
                cart[itemIndex].quantity += change;

                // Xóa nếu số lượng <= 0
                if (cart[itemIndex].quantity <= 0) {
                    cart.splice(itemIndex, 1);
                }

                saveCart();
                updateCartCount();
                loadCartItems();
            }
        }

        function removeFromCart(productId, size, color) {
            cart = cart.filter(item =>
                !(item.id == productId && item.size === size && item.color === color)
            );

            saveCart();
            updateCartCount();
            loadCartItems();
            showNotification('Đã xóa sản phẩm khỏi giỏ hàng');
        }

        // ===========================
        // HIỂN THỊ GIỎ HÀNG
        // ===========================
        function loadCartItems() {
            const cartItemsContainer = document.getElementById('cartItems');
            const cartSummary = document.getElementById('cartSummary');

            if (cart.length === 0) {
                cartItemsContainer.innerHTML = `
            <div class="empty-cart">
                <i class="fas fa-shopping-cart"></i>
                <h3>Giỏ hàng trống</h3>
                <p>Hãy thêm sản phẩm vào giỏ hàng của bạn</p>
            </div>
        `;
                cartSummary.style.display = 'none';
                return;
            }

            let itemsHTML = '';
            let subtotal = 0;

            cart.forEach(item => {
                const itemTotal = item.price * item.quantity;
                subtotal += itemTotal;

                itemsHTML += `
            <div class="cart-item">
                <img src="${item.image}" alt="${item.name}" class="cart-item-image"
                     onerror="this.src='/Images/placeholder.jpg'">
                <div class="cart-item-details">
                    <div class="cart-item-name">${item.name}</div>
                    <div class="cart-item-variant">
                        Size: ${item.size} | Color: ${item.color}
                    </div>
                    <div class="cart-item-price">${formatPrice(itemTotal)} ₫</div>
                    <div class="cart-item-actions">
                        <div class="quantity-controls">
                            <button class="quantity-btn" onclick="updateQuantity('${item.id}', '${item.size}', '${item.color}', -1)">-</button>
                            <input type="text" class="quantity-input" value="${item.quantity}" readonly>
                            <button class="quantity-btn" onclick="updateQuantity('${item.id}', '${item.size}', '${item.color}', 1)">+</button>
                        </div>
                        <button class="remove-item" onclick="removeFromCart('${item.id}', '${item.size}', '${item.color}')">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        `;
            });

            cartItemsContainer.innerHTML = itemsHTML;
            cartSummary.style.display = 'block';

            const total = subtotal;
            document.getElementById('subtotal').textContent = formatPrice(subtotal) + ' ₫';
            document.getElementById('total').textContent = formatPrice(total) + ' ₫';
        }

        // ===========================
        // QUẢN LÝ GIỎ HÀNG
        // ===========================
        function saveCart() {
            localStorage.setItem('evolstore_cart', JSON.stringify(cart));
        }

        function updateCartCount() {
            const cartCount = cart.reduce((total, item) => total + item.quantity, 0);
            const cartCountElement = document.getElementById('cartCount');

            if (cartCount > 0) {
                cartCountElement.textContent = cartCount;
                cartCountElement.style.display = 'flex';
            } else {
                cartCountElement.style.display = 'none';
            }
        }

        // ===========================
        // GIỎ HÀNG SIDEBAR
        // ===========================
        function openCart() {
            document.getElementById('cartSidebar').classList.add('active');
            document.getElementById('cartOverlay').classList.add('active');
            loadCartItems();
        }

        function closeCart() {
            document.getElementById('cartSidebar').classList.remove('active');
            document.getElementById('cartOverlay').classList.remove('active');
        }

        // ===========================
        // TIỆN ÍCH
        // ===========================
        function getProductPrice(productId) {
            // Fallback prices nếu không tìm thấy
            const prices = {
                1: 199000, 2: 299000, 3: 399000, 4: 499000, 5: 259000,
                6: 599000, 7: 799000, 8: 249000, 9: 459000, 10: 529000,
                11: 339000, 12: 499000, 13: 359000, 14: 419000, 15: 689000,
                16: 299000, 17: 449000, 18: 499000, 19: 259000, 20: 559000
            };
            return prices[productId] || 0;
        }

        function formatPrice(price) {
            return price.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }

        function showNotification(message) {
            // Xóa toast cũ nếu có
            const oldToast = document.querySelector('.toast');
            if (oldToast) {
                oldToast.remove();
            }

            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.textContent = message;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.remove();
            }, 3000);
        }

        function checkout() {
    if (cart.length === 0) {
        alert('Giỏ hàng trống!');
        return;
    }

    console.log("=== CHECKOUT CLICKED ===");
    console.log("Cart items:", cart);

    // Mã hóa giỏ hàng thành JSON và truyền qua URL
    const cartData = encodeURIComponent(JSON.stringify(cart));
    window.location.href = '@Url.Action("Index", "Checkout")?cartData=' + cartData;
}

        // ===========================
        // EVENT LISTENERS
        // ===========================
        document.getElementById('cartButton').addEventListener('click', function(e) {
            e.preventDefault();
            openCart();
        });

        document.getElementById('cartOverlay').addEventListener('click', closeCart);

        // Đóng modal khi nhấn ESC
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeModal();
                closeCart();
            }
        });

        // Ngăn sự kiện click trong modal đóng modal
        document.querySelector('.modal-content').addEventListener('click', function(e) {
            e.stopPropagation();
        });
        // ===========================
        // CHAT FUNCTIONALITY
        // ===========================
        $(function () {
            var chat = $.connection.chatHub;
            var isConnected = false;
            var isChatOpen = false;
            var pendingQuestion = null;

            // Mở popup chat
            $('#openChatBtn').click(openChat);

            // Đóng popup chat
            $('#closeChatBtn').click(closeChat);
            $('#chatOverlay').click(closeChat);

            // Đóng khi nhấn ESC
            $(document).keydown(function (e) {
                if (e.keyCode === 27 && isChatOpen) {
                    closeChat();
                }
            });

            function openChat() {
                $('#chatPopup').addClass('active');
                $('#chatOverlay').show();
                isChatOpen = true;
                $('body').css('overflow', 'hidden');
                $('#chatWindow').scrollTop($('#chatWindow')[0].scrollHeight);

                if (!$('#messageInput').prop('disabled')) {
                    $('#messageInput').focus();
                }
            }

            function closeChat() {
                $('#chatPopup').removeClass('active');
                $('#chatOverlay').hide();
                isChatOpen = false;
                $('body').css('overflow', 'auto');
            }

            function showChatNotification(message) {
                var notification = $('<div class="notification">' + message + '</div>');
                $('body').append(notification);

                setTimeout(function () {
                    notification.fadeOut(300, function () {
                        $(this).remove();
                    });
                }, 5000);
            }

            function addChatMessage(content, side) {
                var messageClass = side === 'left' ? 'message-left' : 'message-right';
                var html = '<div class="' + messageClass + '">' +
                    $('<div/>').text(content).html() +
                    '</div>';
                $('#chatWindow').append(html);
                $('#chatWindow').scrollTop($('#chatWindow')[0].scrollHeight);
            }

            function addSystemMessage(message) {
                var html = '<div class="message-center">' +
                    $('<div/>').text(message).html() +
                    '</div>';
                $('#chatWindow').append(html);
                $('#chatWindow').scrollTop($('#chatWindow')[0].scrollHeight);
            }

            function toggleSuggestions(show) {
                if (show) {
                    $('#suggestionsBox').show();
                } else {
                    $('#suggestionsBox').hide();
                }
            }

            $(document).on('click', '.suggestion-btn', function () {
                var question = $(this).data('question');

                if ($('#messageInput').prop('disabled')) {
                    pendingQuestion = question;
                    chat.server.requestSupport();
                    $('#requestButton').prop('disabled', true)
                        .html('<i class="fas fa-spinner fa-spin"></i> Đang chờ...');
                } else {
                    sendMessage(question);
                }
            });

            function sendMessage(message) {
                if (!message.trim()) return;

                addChatMessage('Bạn: ' + message, 'right');
                chat.server.sendMessage(message);
                $('#messageInput').val('').focus();
            }

            chat.client.receiveMessage = function (sender, message) {
                addChatMessage(sender + ': ' + message, 'left');
                if (!isChatOpen) {
                    showChatNotification('💬 Có tin nhắn mới từ nhân viên');
                }
            };

            chat.client.receiveSystemMessage = function (message) {
                addSystemMessage(message);

                if (message.includes("kết nối")) {
                    $('#messageInput').prop('disabled', false);
                    $('#sendButton').prop('disabled', false);
                    $('#requestButton').prop('disabled', true)
                        .html('<i class="fas fa-user-check"></i> Đã kết nối');
                    toggleSuggestions(false);

                    if (pendingQuestion) {
                        setTimeout(function () {
                            sendMessage(pendingQuestion);
                            pendingQuestion = null;
                        }, 1000);
                    }

                    if (isChatOpen) {
                        $('#messageInput').focus();
                    }

                    if (!isChatOpen) {
                        showChatNotification('✅ Nhân viên đã kết nối với bạn');
                    }
                } else if (message.includes("đóng")) {
                    $('#messageInput').prop('disabled', true);
                    $('#sendButton').prop('disabled', true);
                    $('#requestButton').prop('disabled', false)
                        .html('<i class="fas fa-hand-paper"></i> Yêu cầu hỗ trợ');
                    toggleSuggestions(true);
                    pendingQuestion = null;
                }
            };

            $.connection.hub.start().done(function () {
                isConnected = true;
                $('#statusText').text('Đã kết nối máy chủ').css('color', '#4CAF50');

                $('#requestButton').click(function () {
                    chat.server.requestSupport();
                    addSystemMessage("🕒 Đang kết nối với nhân viên hỗ trợ...");
                    $(this).prop('disabled', true)
                        .html('<i class="fas fa-spinner fa-spin"></i> Đang chờ...');
                });

                $('#sendButton').click(function () {
                    var msg = $('#messageInput').val().trim();
                    sendMessage(msg);
                });

                $('#messageInput').keypress(function (e) {
                    if (e.which === 13) {
                        $('#sendButton').click();
                    }
                });

                toggleSuggestions(true);

            }).fail(function (err) {
                console.error('Kết nối thất bại:', err);
                $('#statusText').text('Lỗi kết nối').css('color', '#F44336');
                addSystemMessage("❌ Không thể kết nối đến máy chủ chat");
            });
        });
    </script>
    <!-- ========== PHẦN CHAT ========== -->
    <button class="chat-button" id="openChatBtn">
        <i class="fas fa-comments"></i> <span>Chat hỗ trợ</span>
    </button>

    <!-- Overlay nền tối -->
    <div class="chat-overlay" id="chatOverlay"></div>

    <!-- Popup chat -->
    <div class="chat-popup" id="chatPopup">
        <div class="chat-header">
            <h5><i class="fas fa-headset"></i> Hỗ trợ trực tuyến</h5>
            <button class="close-chat" id="closeChatBtn">
                <i class="fas fa-times"></i>
            </button>
            <div class="chat-status">Trạng thái: <span id="statusText">Chưa kết nối</span></div>
        </div>

        <div class="chat-body">
            <div id="chatWindow">
                <div class="text-center text-muted pt-5">
                    <p style="font-size: 1.1rem; margin-bottom: 5px;">👋 Chào mừng đến với EVOL Store!</p>
                    <p style="font-size: 0.9rem; margin-top: 10px;">Nhấn "Yêu cầu hỗ trợ" để kết nối với nhân viên</p>
                </div>

                <!-- Phần đề xuất câu hỏi -->
                <div id="suggestionsBox" class="suggestions-container">
                    <p class="suggestions-title">💡 Bạn có thể hỏi:</p>
                    <div class="suggestions-list">
                        <button class="suggestion-btn" data-question="Có chương trình khuyến mãi nào không?">
                            <i class="fas fa-gift"></i> Khuyến mãi?
                        </button>
                        <button class="suggestion-btn" data-question="Sản phẩm bán chạy nhất hiện nay là gì?">
                            <i class="fas fa-fire"></i> Sản phẩm hot?
                        </button>
                        <button class="suggestion-btn" data-question="Có ship hàng toàn quốc không?">
                            <i class="fas fa-shipping-fast"></i> Giao hàng?
                        </button>
                        <button class="suggestion-btn" data-question="Tôi muốn đổi trả sản phẩm">
                            <i class="fas fa-exchange-alt"></i> Đổi trả?
                        </button>
                        <button class="suggestion-btn" data-question="Kích thước sản phẩm như thế nào?">
                            <i class="fas fa-ruler"></i> Kích thước?
                        </button>
                        <button class="suggestion-btn" data-question="Tôi muốn xem bộ sưu tập mới">
                            <i class="fas fa-tshirt"></i> Sản phẩm mới?
                        </button>
                    </div>
                </div>
            </div>

            <div class="chat-input-area">
                <div class="input-group">
                    <input type="text" id="messageInput" class="form-control" placeholder="Nhập tin nhắn của bạn..." disabled>
                    <div class="input-group-append">
                        <button id="sendButton" class="btn btn-primary" disabled>
                            <i class="fas fa-paper-plane"></i> Gửi
                        </button>
                        <button id="requestButton" class="btn btn-success">
                            <i class="fas fa-hand-paper"></i> Yêu cầu hỗ trợ
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
