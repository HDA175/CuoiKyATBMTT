@model List<CuoiKy.Models.SanPham>
@{
    Layout = null;
    var selectedLoai = ViewBag.SelectedLoai as string ?? "";
    var selectedChatLieu = ViewBag.SelectedChatLieu as string ?? "";
    var selectedMucGia = ViewBag.SelectedMucGia as string ?? "";
    var searchTerm = ViewBag.SearchTerm as string ?? "";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Cửa Hàng - EvolStore</title>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        /* ===========================
           RESET & VARIABLES
           =========================== */
        :root {
            --header-height: 110px;
            --sidebar-width: 300px;
            --primary: #3498db;
            --primary-dark: #2980b9;
            --danger: #e74c3c;
            --success: #2ecc71;
            --text: #333;
            --muted: #7f8c8d;
            --page-bg: #f8f9fa;
            --border: #e0e0e0;
            --light-bg: #f8f9fa;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        html, body {
            height: 100%;
        }

        body {
            background: var(--page-bg);
            color: var(--text);
            line-height: 1.5;
        }

        /* ===========================
           PRODUCT CARD LINK STYLES
           =========================== */
        .product-card-link {
            display: block;
            text-decoration: none;
            color: inherit;
            transition: transform 0.3s ease;
        }

            .product-card-link:hover {
                text-decoration: none;
                color: inherit;
                transform: translateY(-5px);
            }

                .product-card-link:hover .product-card {
                    transform: translateY(-8px);
                    box-shadow: 0 15px 30px rgba(0,0,0,.15);
                }

        /* Đảm bảo nút vẫn hoạt động bình thường */
        .add-to-cart-btn {
            position: relative;
            z-index: 10;
        }

        /* ===========================
           ANIMATIONS - ĐƠN GIẢN HÓA
           =========================== */
        @@keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes fadeOut {
            from {
                opacity: 1;
                transform: translateX(0);
            }

            to {
                opacity: 0;
                transform: translateX(20px);
            }
        }

        @@keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        /* Apply animations */
        .toast {
            animation: slideIn 0.3s ease;
        }

        .cart-sidebar.active {
            animation: slideInRight 0.4s ease;
        }

        .cart-overlay.active {
            animation: fadeIn 0.4s ease;
        }

        .cart-item.removing {
            animation: fadeOut 0.3s ease forwards;
        }

        /* ===========================
           HEADER
           =========================== */
        .header-top {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background: rgba(0,0,0,.9);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 10%;
            transition: .3s ease;
            box-shadow: 0 2px 10px rgba(0,0,0,.12);
        }

            .header-top.scrolled {
                padding: 12px 10%;
                background: rgba(0,0,0,.95);
            }

            .header-top .logo img {
                width: 200px;
                border-radius: 12px;
                transition: .25s ease;
            }

            .header-top.scrolled .logo img {
                width: 160px;
            }

        .user-actions {
            display: flex;
            gap: 20px;
            align-items: center;
        }

            .user-actions a {
                text-decoration: none;
                color: #fff;
                font-weight: 600;
                padding: 10px 15px;
                border-radius: 8px;
                transition: .25s ease;
                display: flex;
                align-items: center;
                gap: 8px;
                position: relative;
            }

                .user-actions a:hover {
                    background: rgba(255,255,255,.15);
                    color: #a8e6cf;
                    transform: translateY(-2px);
                }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--danger);
            color: white;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            font-size: 0.8rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        /* ===========================
           SEARCH
           =========================== */
        .search-container {
            display: flex;
            align-items: center;
            position: relative;
        }

        .search-box {
            display: flex;
            align-items: center;
            background: rgba(255,255,255,.1);
            border-radius: 30px;
            padding: 8px 15px;
            transition: all .35s ease;
            width: 50px;
            overflow: hidden;
            cursor: pointer;
            border: 1px solid transparent;
        }

            .search-box.active {
                width: 280px;
                background: rgba(255,255,255,.15);
                cursor: text;
                border-color: rgba(255,255,255,.3);
            }

        .search-icon {
            color: #fff;
            font-size: 18px;
            transition: .25s ease;
            flex-shrink: 0;
        }

        .search-box:hover .search-icon {
            color: #a8e6cf;
            transform: scale(1.1);
        }

        .search-box.active .search-icon {
            color: #a8e6cf;
        }

        .search-input {
            border: none !important;
            outline: none !important;
            box-shadow: none !important;
            background: transparent !important;
            color: #fff;
            font-size: 15px;
            padding: 8px 12px;
            width: 0;
            opacity: 0;
            transition: .25s ease;
            appearance: none;
            -webkit-appearance: none;
        }

            .search-input::placeholder {
                color: rgba(255,255,255,.7);
            }

        .search-box.active .search-input {
            width: 100%;
            opacity: 1;
        }

        /* ===========================
           LAYOUT CHÍNH
           =========================== */
        .main-content {
            display: flex;
            margin-top: var(--header-height);
            padding-bottom: 100px;
            min-height: calc(100vh - var(--header-height));
        }

        /* ===========================
           SIDEBAR CATEGORIES
           =========================== */
        .categories-sidebar {
            width: var(--sidebar-width);
            background: #fff;
            margin-top: 75px;
            padding: 30px 20px;
            box-shadow: 2px 0 10px rgba(0,0,0,.08);
            position: sticky;
            top: calc(var(--header-height) + 10px);
            align-self: flex-start;
            height: auto;
        }

        .categories-title {
            font-size: 1.6rem;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid var(--primary);
        }

        .category-section {
            margin-bottom: 30px;
        }

        .category-section-title {
            font-size: 1.15rem;
            font-weight: 600;
            color: #34495e;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .category-section-title i {
                color: var(--primary);
            }

        .category-list {
            list-style: none;
        }

        .category-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 15px;
            background: #f8f9fa;
            border-radius: 8px;
            color: #555;
            text-decoration: none;
            margin-bottom: 8px;
            transition: .25s ease;
            border-left: 3px solid transparent;
        }

            .category-link:hover {
                background: #e9ecef;
                color: var(--primary);
                border-left-color: var(--primary);
                transform: translateX(5px);
            }

            .category-link.active {
                background: var(--primary);
                color: #fff;
                border-left-color: #1e70b8;
            }

        .category-count {
            margin-left: auto;
            font-size: .8rem;
            background: rgba(0,0,0,.1);
            padding: 4px 10px;
            border-radius: 12px;
            font-weight: 600;
        }

        .category-link.active .category-count {
            background: rgba(255,255,255,.3);
        }

        /* ===========================
           PRODUCTS
           =========================== */
        .products-section {
            flex: 1;
            margin-left: 100px;
            margin-top: 75px;
            padding: 40px 5% 100px;
            min-height: 100%;
        }

        .section-title {
            text-align: center;
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 30px;
        }

        .product-count {
            text-align: center;
            color: var(--muted);
            margin-bottom: 30px;
            font-weight: 500;
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .product-card {
            background: #fff;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,.08);
            transition: .25s ease;
            position: relative;
            height: 535px;
            display: flex;
            flex-direction: column;
        }

            .product-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 12px 20px rgba(0,0,0,.15);
            }

        .product-image {
            width: 100%;
            height: 300px;
            object-fit: cover;
            background: #f5f5f5;
            transition: transform .45s ease;
        }

        .product-card:hover .product-image {
            transform: scale(1.05);
        }

        .product-info {
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            flex: 1;
        }

        .product-name {
            font-size: 1.2rem;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 10px;
            line-height: 1.4;
            height: 3.4em;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
        }

        .product-price {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--danger);
            margin-bottom: 15px;
        }

        .add-to-cart-btn {
            width: 100%;
            padding: 12px;
            background: var(--primary);
            border: none;
            color: #fff;
            font-weight: 600;
            border-radius: 8px;
            cursor: pointer;
            transition: .2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .add-to-cart-btn:hover {
                background: var(--primary-dark);
                transform: scale(1.02);
            }

            .add-to-cart-btn:disabled {
                background: #bdc3c7;
                color: #7f8c8d;
                cursor: not-allowed;
                transform: none;
            }

            .add-to-cart-btn i {
                font-size: 1.1rem;
            }

        .out-of-stock {
            position: absolute;
            top: 15px;
            right: 15px;
            z-index: 10;
            background: rgba(231,76,60,.9);
            color: #fff;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: .85rem;
            font-weight: 600;
        }

        .no-products {
            text-align: center;
            padding: 60px 30px;
            background: #fff;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,.1);
            grid-column: 1 / -1;
        }

            .no-products i {
                font-size: 5rem;
                color: #bdc3c7;
                margin-bottom: 20px;
            }

            .no-products h3 {
                font-size: 1.8rem;
                color: #7f8c8d;
                margin-bottom: 15px;
            }

            .no-products p {
                color: #95a5a6;
                font-size: 1.1rem;
            }

        /* ===========================
           CART SIDEBAR
           =========================== */
        .cart-sidebar {
            position: fixed;
            top: 0;
            right: -600px;
            width: 580px;
            height: 100vh;
            background: white;
            box-shadow: -5px 0 25px rgba(0,0,0,0.15);
            transition: right 0.4s ease;
            z-index: 10000;
            display: flex;
            flex-direction: column;
        }

            .cart-sidebar.active {
                right: 0;
            }

        .cart-header {
            padding: 25px;
            background: var(--primary);
            color: white;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .cart-title {
            font-size: 1.4rem;
            font-weight: 700;
        }

        .close-cart {
            background: none;
            border: none;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            padding: 5px;
            border-radius: 50%;
            transition: background 0.3s ease;
        }

            .close-cart:hover {
                background: rgba(255,255,255,0.2);
            }

        .cart-content {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
        }

        .cart-items {
            margin-bottom: 20px;
        }

        .cart-item {
            display: flex;
            padding: 15px 0;
            border-bottom: 1px solid var(--border);
            position: relative;
        }

        .cart-item-image {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 8px;
            margin-right: 15px;
        }

        .cart-item-details {
            flex: 1;
        }

        .cart-item-name {
            font-weight: 600;
            margin-bottom: 5px;
            font-size: 0.95rem;
        }

        .cart-item-variant {
            font-size: 0.8rem;
            color: var(--muted);
            margin-bottom: 8px;
        }

        .cart-item-price {
            font-weight: 700;
            color: var(--danger);
            font-size: 1rem;
        }

        .cart-item-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 8px;
        }

        .quantity-controls {
            display: flex;
            align-items: center;
            border: 1px solid var(--border);
            border-radius: 20px;
            overflow: hidden;
        }

        .quantity-btn {
            background: none;
            border: none;
            padding: 5px 12px;
            cursor: pointer;
            font-size: 1rem;
            transition: background 0.3s ease;
        }

            .quantity-btn:hover:not(:disabled) {
                background: var(--light-bg);
            }

            .quantity-btn:disabled {
                color: #bdc3c7;
                cursor: not-allowed;
            }

        .quantity-input {
            width: 40px;
            text-align: center;
            border: none;
            background: transparent;
            font-weight: 600;
        }

        .remove-item {
            background: none;
            border: none;
            color: var(--danger);
            cursor: pointer;
            padding: 5px;
            border-radius: 50%;
            transition: background 0.3s ease;
        }

            .remove-item:hover {
                background: rgba(231, 76, 60, 0.1);
            }

        .cart-summary {
            padding: 20px;
            background: white;
            border-top: 2px solid var(--border);
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 0.95rem;
        }

        .summary-total {
            font-weight: 700;
            font-size: 1.2rem;
            color: var(--danger);
            border-top: 1px solid var(--border);
            padding-top: 10px;
            margin-top: 10px;
        }

        .checkout-btn {
            width: 100%;
            padding: 15px;
            background: var(--success);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s ease;
            margin-top: 15px;
        }

            .checkout-btn:hover {
                background: #27ae60;
            }

        .empty-cart {
            text-align: center;
            padding: 60px 20px;
            color: var(--muted);
        }

            .empty-cart i {
                font-size: 4rem;
                margin-bottom: 20px;
                color: #bdc3c7;
            }

            .empty-cart h3 {
                margin-bottom: 10px;
                font-size: 1.3rem;
            }

        /* Overlay */
        .cart-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 9999;
            opacity: 0;
            visibility: hidden;
            transition: all 0.4s ease;
        }

            .cart-overlay.active {
                opacity: 1;
                visibility: visible;
            }

        /* Continue Shopping Button */
        .continue-shopping {
            display: block;
            text-align: center;
            padding: 12px;
            background: var(--primary);
            color: white;
            text-decoration: none;
            border-radius: 8px;
            margin-top: 15px;
            transition: background 0.3s ease;
        }

            .continue-shopping:hover {
                background: var(--primary-dark);
                color: white;
                text-decoration: none;
            }

        /* Toast Notification */
        .toast {
            position: fixed;
            top: 100px;
            right: 20px;
            background: #2ecc71;
            color: white;
            padding: 15px 20px;
            border-radius: 5px;
            z-index: 10001;
        }

        .user-actions {
            display: flex;
            gap: 20px;
            align-items: center;
        }

            .user-actions a {
                text-decoration: none;
                color: white;
                font-size: 16px;
                font-weight: bold;
                display: flex;
                align-items: center;
                gap: 8px;
                padding: 10px 15px;
                border-radius: 5px;
                transition: all 0.3s ease;
            }

                .user-actions a:hover {
                    background-color: rgba(255, 255, 255, 0.1);
                    color: rgb(190, 230, 228);
                }

        /* CSS cho dropdown menu - SỬA ĐỔI QUAN TRỌNG */
        .user-dropdown {
            position: relative;
            display: inline-block;
        }
        /* ========== CHAT STYLES ========== */
/* Nút mở chat */
.chat-button {
    position: fixed;
    bottom: 25px;
    right: 100px;
    z-index: 999;
    background: linear-gradient(135deg, #27c9cc, #1a8a8c);
    color: white;
    border: none;
    border-radius: 50px;
    padding: 15px 30px;
    box-shadow: 0 4px 20px rgba(39, 201, 204, 0.4);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
    font-weight: 600;
    font-size: 1.1rem;
}

.chat-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(39, 201, 204, 0.5);
    padding: 15px 35px;
}

.chat-button i {
    font-size: 1.4rem;
}

/* Popup chat - ẨN MẶC ĐỊNH */
.chat-popup {
    display: none; /* Ẩn mặc định */
    position: fixed;
    bottom: 90px;
    right: 25px;
    z-index: 1001;
    width: 450px;
    height: 600px;
    max-width: 90vw;
    max-height: 80vh;
    background: white;
    border-radius: 15px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.25);
    overflow: hidden;
    animation: slideInUp 0.3s ease;
    flex-direction: column;
}

/* Class active sẽ hiển thị chat */
.chat-popup.active {
    display: flex !important;
}

@@keyframes slideInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.chat-header {
    background: linear-gradient(135deg, #27c9cc, #1a8a8c);
    color: white;
    padding: 20px;
    position: relative;
    flex-shrink: 0;
}

.chat-header h5 {
    margin: 0;
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    gap: 10px;
}

.close-chat {
    position: absolute;
    right: 20px;
    top: 20px;
    background: rgba(255,255,255,0.2);
    border: none;
    color: white;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    font-size: 1.1rem;
}

.close-chat:hover {
    background: rgba(255,255,255,0.3);
    transform: rotate(90deg);
    width: 35px;
    height: 35px;
}

.chat-status {
    font-size: 0.9rem;
    opacity: 0.9;
    margin-top: 8px;
}

.chat-body {
    background: #fafafa;
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

#chatWindow {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    background: white;
    min-height: 0;
    display: flex;
    flex-direction: column;
}

.chat-input-area {
    padding: 20px;
    border-top: 1px solid #eee;
    background: white;
    flex-shrink: 0;
}

/* Tin nhắn */
.message-left {
    background: #f1f1f1;
    padding: 12px 16px;
    border-radius: 18px 18px 18px 4px;
    margin-bottom: 12px;
    max-width: 85%;
    align-self: flex-start;
    font-size: 1rem;
    line-height: 1.4;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    word-wrap: break-word;
}

.message-right {
    background: linear-gradient(135deg, #27c9cc, #1a8a8c);
    color: white;
    padding: 12px 16px;
    border-radius: 18px 18px 4px 18px;
    margin-bottom: 12px;
    max-width: 85%;
    align-self: flex-end;
    font-size: 1rem;
    line-height: 1.4;
    box-shadow: 0 2px 8px rgba(39, 201, 204, 0.2);
    word-wrap: break-word;
}

.message-center {
    background: #fff3cd;
    color: #856404;
    padding: 10px 15px;
    border-radius: 8px;
    margin: 10px auto;
    text-align: center;
    max-width: 90%;
    font-size: 0.9rem;
    border: 1px solid #ffeaa7;
    clear: both;
}

/* Đề xuất câu hỏi */
.suggestions-container {
    background: #f8f9fa;
    border-radius: 12px;
    padding: 15px;
    margin: 15px 10px;
    border: 1px solid #e9ecef;
    display: block;
}

.suggestions-title {
    font-weight: 600;
    color: #27c9cc;
    margin-bottom: 10px;
    font-size: 0.95rem;
    text-align: center;
}

.suggestions-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
}

.suggestion-btn {
    background: white;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 10px 15px;
    text-align: left;
    font-size: 0.85rem;
    color: #333;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.suggestion-btn:hover {
    background: #27c9cc;
    color: white;
    border-color: #27c9cc;
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(39, 201, 204, 0.2);
}

.suggestion-btn i {
    font-size: 0.9rem;
    min-width: 20px;
}

/* Scrollbar chat */
#chatWindow::-webkit-scrollbar {
    width: 8px;
}

#chatWindow::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 4px;
}

#chatWindow::-webkit-scrollbar-thumb {
    background: #ccc;
    border-radius: 4px;
}

#chatWindow::-webkit-scrollbar-thumb:hover {
    background: #aaa;
}

/* Overlay chat */
.chat-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.6);
    z-index: 998;
    backdrop-filter: blur(3px);
}

/* Form input */
#messageInput {
    padding: 12px 15px;
    font-size: 1rem;
    border-radius: 8px;
    border: 1px solid #ddd;
    transition: border 0.3s;
    width: 100%;
    margin-bottom: 10px;
}

#messageInput:focus {
    border-color: #27c9cc;
    box-shadow: 0 0 0 0.2rem rgba(39, 201, 204, 0.25);
    outline: none;
}

.input-group {
    display: flex;
    gap: 10px;
}

#sendButton, #requestButton {
    padding: 12px 20px;
    font-size: 1rem;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    flex: 1;
}

.btn-primary {
    background: linear-gradient(135deg, #27c9cc, #1a8a8c);
    border: none;
    color: white;
}

.btn-success {
    background: linear-gradient(135deg, #28a745, #1e7e34);
    border: none;
    color: white;
}

.btn-primary:hover, .btn-success:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
}

/* Thông báo */
.notification {
    position: fixed;
    top: 25px;
    right: 25px;
    background: linear-gradient(135deg, #27c9cc, #1a8a8c);
    color: white;
    padding: 15px 20px;
    border-radius: 10px;
    z-index: 2000;
    box-shadow: 0 6px 20px rgba(0,0,0,0.25);
    animation: fadeInOut 5s;
    font-size: 1rem;
    font-weight: 500;
    max-width: 350px;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2);
}

@@keyframes fadeInOut {
    0% {
        opacity: 0;
        transform: translateY(-20px) scale(0.95);
    }
    15% {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
    85% {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
    100% {
        opacity: 0;
        transform: translateY(-20px) scale(0.95);
    }
}
        /* ===========================
   DISCOUNT STYLES
   =========================== */
        .discount-badge {
            position: absolute;
            top: 15px;
            left: 15px;
            z-index: 10;
            background: linear-gradient(135deg, #ff6b9d, #ff4757);
            color: white;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 700;
            box-shadow: 0 4px 10px rgba(255, 107, 157, 0.3);
        }

        .product-price-container {
            display: flex;
            flex-direction: column;
            gap: 5px;
            margin-bottom: 10px;
        }

        .original-price {
            font-size: 1rem;
            color: #95a5a6;
            text-decoration: line-through;
            font-weight: 500;
        }

        .discounted-price {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--danger);
        }

        .save-amount {
            font-size: 0.85rem;
            color: var(--success);
            font-weight: 600;
            background: rgba(46, 204, 113, 0.1);
            padding: 6px 10px;
            border-radius: 6px;
            display: inline-block;
            margin-top: 5px;
        }

        /* Điều chỉnh lại vị trí out-of-stock để không bị chồng lên discount-badge */
        .out-of-stock {
            position: absolute;
            top: 15px;
            right: 15px;
            z-index: 10;
            background: rgba(231,76,60,.9);
            color: #fff;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: .85rem;
            font-weight: 600;
        }
/* Loading */
.fa-spinner {
    animation: spin 1s linear infinite;
}

@@keyframes spin {
    0% {
        transform: rotate(0deg);
    }
    100% {
        transform: rotate(360deg);
    }
}

/* Responsive cho chat */
@@media (max-width: 768px) {
    .chat-button {
        right: 20px;
        bottom: 20px;
        padding: 12px 25px;
        font-size: 1rem;
    }

    .chat-popup {
        right: 50%;
        transform: translateX(50%);
        width: 380px;
        height: 550px;
        max-width: 95vw;
        max-height: 85vh;
    }
}

@@media (max-width: 480px) {
    .chat-popup {
        width: 95vw;
        height: 85vh;
        right: 2.5vw;
        transform: none;
        bottom: 10px;
    }

    .chat-button {
        padding: 10px 20px;
        font-size: 0.95rem;
        right: 15px;
        bottom: 15px;
    }

    .suggestions-list {
        grid-template-columns: 1fr;
    }

    .input-group {
        flex-direction: column;
    }
}
        .user-info {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 15px;
            border-radius: 5px;
            color: white;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            min-width: 200px;
        }

