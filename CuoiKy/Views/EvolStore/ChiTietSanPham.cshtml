﻿@model CuoiKy.Models.SanPham
@using CuoiKy.Models
@{
    Layout = null;
    var sanPhamLienQuan = ViewBag.SanPhamLienQuan as List<CuoiKy.Models.SanPham> ?? new List<CuoiKy.Models.SanPham>();
    var danhGiaList = ViewBag.DanhGia as List<DanhGia> ?? new List<DanhGia>();
    var diemTrungBinh = ViewBag.DiemTrungBinh != null ? (double)ViewBag.DiemTrungBinh : 0;
    var tongDanhGia = ViewBag.TongDanhGia != null ? (int)ViewBag.TongDanhGia : 0;
    var searchTerm = ViewBag.SearchTerm as string ?? "";

    // Tính toán giảm giá cho sản phẩm chính
    decimal phanTramGiam = 0;
    decimal giaGoc = Model.Gia;
    bool coGiamGia = false;
    decimal soTienGiam = 0;

    if (Model.GiamGias != null && Model.GiamGias.Any())
    {
        var giamGiaHienTai = Model.GiamGias
            .Where(g => g.NgayBatDau <= DateTime.Now &&
                       (g.NgayKetThuc == null || g.NgayKetThuc >= DateTime.Now))
            .OrderByDescending(g => g.PhanTramGiam)
            .FirstOrDefault();

        if (giamGiaHienTai != null && giamGiaHienTai.PhanTramGiam > 0)
        {
            phanTramGiam = Math.Round(giamGiaHienTai.PhanTramGiam * 100, 0);
            giaGoc = Math.Round(Model.Gia / (1 - giamGiaHienTai.PhanTramGiam), 0);
            soTienGiam = giaGoc - Model.Gia;
            coGiamGia = true;
        }
    }
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@Model.TenSP - EvolStore</title>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        /* ===========================
           RESET & VARIABLES
           =========================== */
        :root {
            --header-height: 110px;
            --sidebar-width: 300px;
            --primary: #3498db;
            --primary-dark: #2980b9;
            --danger: #e74c3c;
            --danger-light: #ff6b9d;
            --success: #2ecc71;
            --warning: #f39c12;
            --text: #333;
            --muted: #7f8c8d;
            --page-bg: #f8f9fa;
            --border: #e0e0e0;
            --light-bg: #f8f9fa;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        html, body {
            height: 100%;
        }

        body {
            background: var(--page-bg);
            color: var(--text);
            line-height: 1.5;
        }

        /* ===========================
           HEADER
           =========================== */
        .header-top {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background: rgba(0,0,0,.9);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 10%;
            transition: .3s ease;
            box-shadow: 0 2px 10px rgba(0,0,0,.12);
        }

            .header-top.scrolled {
                padding: 12px 10%;
                background: rgba(0,0,0,.95);
            }

            .header-top .logo img {
                width: 200px;
                border-radius: 12px;
                transition: .25s ease;
            }

            .header-top.scrolled .logo img {
                width: 160px;
            }

        .user-actions {
            display: flex;
            gap: 20px;
            align-items: center;
        }

            .user-actions a {
                text-decoration: none;
                color: #fff;
                font-weight: 600;
                padding: 10px 15px;
                border-radius: 8px;
                transition: .25s ease;
                display: flex;
                align-items: center;
                gap: 8px;
                position: relative;
            }

                .user-actions a:hover {
                    background: rgba(255,255,255,.15);
                    color: #a8e6cf;
                    transform: translateY(-2px);
                }

        .cart-count {
            position: absolute;
            top: -8px;
            right: -8px;
            background: var(--danger);
            color: white;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            font-size: 0.8rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        /* ===========================
           USER DROPDOWN
           =========================== */
        .user-dropdown {
            position: relative;
            display: inline-block;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 15px;
            border-radius: 5px;
            color: white;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            min-width: 200px;
        }

            .user-info:hover {
                background-color: rgba(255, 255, 255, 0.2);
                color: rgb(190, 230, 228);
            }

        .dropdown-arrow {
            font-size: 12px;
            transition: transform 0.3s ease;
            margin-left: auto;
        }

        .dropdown-menu {
            position: absolute;
            top: 100%;
            right: 0;
            width: 200px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            opacity: 0;
            visibility: hidden;
            transform: translateY(-10px);
            transition: all 0.3s ease;
            z-index: 1001;
            padding: 8px 0;
        }

        .user-dropdown:hover .dropdown-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            text-decoration: none;
            color: black !important;
            font-size: 14px;
            font-weight: normal;
            transition: all 0.2s ease;
            border-bottom: 1px solid #f0f0f0;
        }

            .dropdown-item:last-child {
                border-bottom: none;
            }

            .dropdown-item:hover {
                background-color: #f8f9fa;
                color: #007bff !important;
            }

            .dropdown-item i {
                width: 16px;
                text-align: center;
                font-size: 14px;
            }

        .logout-item:hover {
            background-color: #fff5f5 !important;
            color: #dc3545 !important;
        }

        /* ===========================
           SEARCH
           =========================== */
        .search-container {
            display: flex;
            align-items: center;
            position: relative;
        }

        .search-box {
            display: flex;
            align-items: center;
            background: rgba(255,255,255,.1);
            border-radius: 30px;
            padding: 8px 15px;
            transition: all .35s ease;
            width: 50px;
            overflow: hidden;
            cursor: pointer;
            border: 1px solid transparent;
        }

