            display: block;
            margin-bottom: 12px;
            color: #2c3e50;
            font-weight: 600;
            font-size: 1.1rem;
        }

        .size-options, .color-options {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .size-option, .color-option {
            padding: 12px 20px;
            border: 2px solid var(--border);
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
            min-width: 60px;
            font-weight: 500;
        }

            .size-option:hover, .color-option:hover {
                border-color: var(--primary);
                background: rgba(52, 152, 219, 0.1);
            }

            .size-option.selected, .color-option.selected {
                border-color: var(--primary);
                background: var(--primary);
                color: white;
            }

        .color-option {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 15px;
        }

        .color-dot {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: 2px solid #fff;
            box-shadow: 0 0 0 1px var(--border);
        }

        /* ===========================
           ACTION SECTION
           =========================== */
        .action-section {
            display: flex;
            gap: 15px;
            align-items: center;
            margin: 30px 0;
            flex-wrap: wrap;
        }

        .quantity-selector {
            display: flex;
            align-items: center;
            border: 2px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
            background: white;
        }

        .quantity-btn {
            width: 45px;
            height: 45px;
            border: none;
            background: #f8f9fa;
            cursor: pointer;
            font-size: 1.2rem;
            font-weight: bold;
            transition: background 0.3s;
        }

            .quantity-btn:hover:not(:disabled) {
                background: #e9ecef;
            }

            .quantity-btn:disabled {
                color: #bdc3c7;
                cursor: not-allowed;
            }

        .quantity-input {
            width: 60px;
            height: 45px;
            border: none;
            text-align: center;
            font-size: 1.1rem;
            font-weight: 700;
            outline: none;
            background: white;
        }

        .add-to-cart-btn {
            flex: 1;
            min-width: 200px;
            padding: 15px 30px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(52, 152, 219, 0.3);
        }

            .add-to-cart-btn:hover:not(:disabled) {
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(52, 152, 219, 0.4);
            }

            .add-to-cart-btn:disabled {
                background: #bdc3c7;
                cursor: not-allowed;
                transform: none;
                box-shadow: none;
            }

        .buy-now-btn {
            flex: 1;
            min-width: 200px;
            padding: 15px 30px;
            background: linear-gradient(135deg, var(--success), #27ae60);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 15px rgba(46, 204, 113, 0.3);
        }

            .buy-now-btn:hover {
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(46, 204, 113, 0.4);
            }

        /* ===========================
           RATING SECTION
           =========================== */
        .rating-section {
            margin: 40px 0;
            padding: 40px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
        }

        .rating-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 30px;
            color: #2c3e50;
            border-bottom: 3px solid var(--primary);
            padding-bottom: 10px;
            display: inline-block;
        }

        .rating-header {
            display: flex;
            align-items: center;
            gap: 40px;
            margin-bottom: 30px;
            padding-bottom: 20px;
