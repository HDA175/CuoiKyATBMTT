            font-weight: 700;
            color: #2c3e50;
            line-height: 1.2;
        }

        /* ===========================
           PRICE STYLES WITH DISCOUNT
           =========================== */
        .price-container {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 10px;
            border: 2px solid #e9ecef;
        }

        .discount-tag {
