            color: #fff;
            font-size: 15px;
            padding: 8px 12px;
            width: 0;
            opacity: 0;
            transition: .25s ease;
        }

            .search-input::placeholder {
                color: rgba(255,255,255,.7);
            }

        .search-box.active .search-input {
            width: 100%;
            opacity: 1;
        }

        /* ===========================
           PRODUCT DETAIL STYLES
           =========================== */
        .product-detail-container {
            margin-top: 150px;
            padding: 40px 10%;
            min-height: calc(100vh - var(--header-height));
        }

        .back-to-shop {
