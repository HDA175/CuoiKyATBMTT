@{
    Layout = null;
    ViewBag.Title = "Đăng nhập";
    string returnUrl = ViewBag.ReturnUrl as string;
}

<!-- ============= CSS ============= -->
<style>
    .login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 16px;
        background: linear-gradient(135deg, #f3f4f6, #ffffff);
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #111827;
    }

    .login-wrapper {
        width: 100%;
        max-width: 960px;
    }

    .login-card {
        background: #ffffff;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.12);
        border: 1px solid #e5e7eb;
    }

    .login-left {
        background:
            radial-gradient(circle at top left, rgba(229, 231, 235, 0.8), transparent 60%),
            linear-gradient(135deg, #e5e7eb, #d1d5db);
        padding: 32px;
        color: #111827;
    }

    .login-brand {
        margin: auto 0;
    }

    .brand-title {
        font-size: 32px;
        font-weight: 800;
        color: #111827;
        letter-spacing: 0.04em;
    }

    .brand-subtitle {
        margin-top: 12px;
        font-size: 15px;
        color: #4b5563;
        max-width: 260px;
        line-height: 1.6;
    }

    .login-right {
        padding: 32px;
        background: #f9fafb;
    }

    .login-inner {
        max-width: 420px;
        margin: 0 auto;
    }

    .login-title {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
    }

    .login-subtitle {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 1.75rem;
    }

    .form-group-login {
        margin-bottom: 1.25rem;
    }

    /* 2 ô textbox dùng chung class này => luôn thẳng hàng */
    .login-input {
        display: block;
        width: 100%;
        box-sizing: border-box;
        background-color: #f9fafb;
        border-radius: 12px;
        border: 1px solid #d1d5db;
        padding: 11px 13px;
        font-size: 14px;
        color: #111827;
        transition: border-color 0.18s ease, box-shadow 0.18s ease, background-color 0.18s;
    }

    .login-input::placeholder {
        color: #9ca3af;
    }

    .login-input:focus {
        background-color: #ffffff;
        border-color: #111827;
        outline: none;
        box-shadow: 0 0 0 1px rgba(17, 24, 39, 0.15);
    }

    /* Ô mật khẩu + icon mắt */
    .password-wrapper {
        position: relative;
    }

    /* chừa chỗ bên phải cho icon, nhưng vẫn full width = cùng hàng với ô trên */
    .password-wrapper .login-input {
        padding-right: 40px;
    }

    .btn-password-toggle {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        width: 28px;
        height: 28px;
        border-radius: 999px;
        border: none;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        padding: 0;
        color: #6b7280;
    }

    .btn-password-toggle:hover {
        background: #e5e7eb;
        color: #111827;
    }

    .icon-eye {
        width: 18px;
        height: 18px;
    }

    .hidden {
        display: none;
    }

    .link-small {
        font-size: 13px;
        color: #6b7280;
        text-decoration: none;
    }

    .link-small:hover {
        color: #111827;
        text-decoration: underline;
    }

    .login-btn {
        border-radius: 999px;
        font-weight: 600;
        border: 1px solid #111827;
        padding: 11px 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: linear-gradient(135deg, #ffffff, #e5e7eb);
        box-shadow: 0 10px 25px rgba(15, 23, 42, 0.15);
        transition: transform 0.12s ease, box-shadow 0.12s ease, opacity 0.12s;
        color: #111827;
        font-size: 14px;
        width: 100%;
        box-sizing: border-box;
    }

    .login-btn:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 16px 35px rgba(15, 23, 42, 0.18);
        color: #000000;
    }

    .login-btn:active:not(:disabled) {
        transform: translateY(0);
        box-shadow: 0 7px 18px rgba(15, 23, 42, 0.16);
    }

    .login-btn:disabled {
        opacity: 0.7;
        cursor: default;
    }

    .divider {
        position: relative;
        text-align: center;
        font-size: 13px;
        color: #9ca3af;
        margin: 1.75rem 0;
    }

    .divider::before,
    .divider::after {
        content: "";
        position: absolute;
        top: 50%;
        width: 40%;
        height: 1px;
        background-color: #e5e7eb;
    }

    .divider::before {
        left: 0;
    }

    .divider::after {
        right: 0;
    }

    .divider span {
        display: inline-block;
        padding: 0 8px;
        background: #f9fafb;
    }

    .btn-google {
        border-radius: 999px;
        border: 1px solid #d1d5db;
        background-color: #ffffff;
        color: #111827;
        padding: 9px 14px;
        font-size: 14px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        box-sizing: border-box;
        transition: background-color 0.15s ease, border-color 0.15s ease, transform 0.1s ease, box-shadow 0.1s ease;
    }

    .btn-google:hover:not(:disabled) {
        background-color: #f3f4f6;
        border-color: #9ca3af;
        color: #000000;
        text-decoration: none;
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(148, 163, 184, 0.35);
    }

    .btn-google:disabled {
        opacity: 0.7;
        cursor: default;
        transform: none;
        box-shadow: none;
    }

    .google-icon {
        width: 18px;
        height: 18px;
        border-radius: 4px;
        background: #111827;
        color: #f9fafb;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
    }

    .signup-text {
        font-size: 13px;
        color: #6b7280;
        text-align: center;
        margin-top: 1.5rem;
    }

    .signup-text a {
        color: #111827;
        font-weight: 500;
        text-decoration: none;
    }

    .signup-text a:hover {
        text-decoration: underline;
    }
    div.logo {
        text-align: center;
        margin-bottom: 75px;
    }

    div > a > img {
        width: 200px;
        border-radius: 15px;
        transition: all 0.3s ease;
    }

        div > a > img:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
    @@media (max-width: 991.98px) {
        .login-card {
            border-radius: 20px;
        }

        .login-right {
            padding: 24px 20px;
        }

        .login-page {
            padding: 16px;
        }
    }
</style>

<!-- ============= VIEW ============= -->
<div class="login-page">
    <div class="login-wrapper">
        <div class="login-card row g-0">
            <!-- Cột trái -->
            <div class="col-lg-6 login-left d-none d-lg-flex">
                <div class="login-brand">
                    <h1 class="brand-title">ĐĂNG NHẬP</h1>
                    <div class="logo">
                        <a href="@Url.Action("Index", "EvolStore")">
                            <img src="/images/logo.jpg" alt="logo" />
                        </a>
                    </div>
                </div>
            </div>

            <!-- Cột phải -->
            <div class="col-lg-6 login-right">
                <div class="login-inner">
                    <h2 class="login-title mb-1">Welcome back 👋</h2>

                    @* Thông báo lỗi / thông tin *@
                    @if (TempData["AutoLogoutMessage"] != null)
                    {
                        <div class="alert alert-info" style="margin: 8px 0 16px 0; padding: 10px 12px; border-radius: 8px;">
                            @TempData["AutoLogoutMessage"]
                        </div>
                    }
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" style="margin: 8px 0 16px 0; padding: 10px 12px; border-radius: 8px;">
                            @ViewBag.Error
                        </div>
                    }

                    @* FORM ĐĂNG NHẬP *@
                    @using (Html.BeginForm("Login", "User", FormMethod.Post, new { @class = "form-horizontal", id = "loginForm" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-2" })
                        @Html.Hidden("returnUrl", returnUrl)

                        <div class="form-group-login">
                            <label for="TenDangNhap" class="form-label">Tên đăng nhập</label>
                            @Html.TextBox("TenDangNhap", null, new
                            {
                                @class = "login-input",
                                placeholder = "Tên đăng nhập",
                                autocomplete = "username",
                                id = "TenDangNhap"
                            })
                        </div>

                        <div class="form-group-login password-wrapper">
                            <label for="MatKhau" class="form-label">Mật khẩu</label>
                            @Html.Password("MatKhau", null, new
                            {
                                @class = "login-input",
                                placeholder = "Mật khẩu",
                                autocomplete = "current-password",
                                id = "MatKhau"
                            })
                            <button type="button"
                                    class="btn-password-toggle"
                                    id="btnTogglePassword"
                                    aria-label="Ẩn/hiện mật khẩu">
                                <!-- Mắt mở -->
                                <svg id="iconEyeOpen" class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                                <!-- Mắt gạch chéo -->
                                <svg id="iconEyeSlash" class="icon-eye hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                     stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-7 0-11-7-11-7a21.77 21.77 0 0 1 5.06-5.94" />
                                    <path d="M9.9 4.24A10.94 10.94 0 0 1 12 5c7 0 11 7 11 7a21.64 21.64 0 0 1-3.17 4.15" />
                                    <line x1="1" y1="1" x2="23" y2="23" />
                                </svg>
                            </button>
                        </div>

                        <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 1.1rem;">
                            <div class="form-check">
                                <input type="checkbox"
                                       class="form-check-input"
                                       id="RememberMe"
                                       name="RememberMe"
                                       value="true" />
                                <label class="form-check-label" for="RememberMe">Ghi nhớ đăng nhập</label>
                            </div>
                            <a href="#" class="link-small">Quên mật khẩu?</a>
                        </div>

                        <div class="form-group-login" style="margin-bottom: 1rem;">
                            <div class="g-recaptcha" data-sitekey="@System.Configuration.ConfigurationManager.AppSettings["ReCaptchaSiteKey"]"></div>
                        </div>

                        <button type="submit" class="login-btn" id="btnLogin">
                            Đăng nhập
                        </button>
                    }

                    <div class="divider">
                        <span>Hoặc</span>
                    </div>

                    @* NÚT GOOGLE *@
                    @using (Html.BeginForm("GoogleLogin", "User", FormMethod.Post, new { @class = "mb-2", id = "googleForm" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("returnUrl", returnUrl)

                        <button type="submit" class="btn-google" id="btnGoogleLogin">
                            <span class="google-icon">G</span>
                            <span>Đăng nhập với Google</span>
                        </button>
                    }

                    <p class="signup-text">
                        Chưa có tài khoản?
                        <a href="@Url.Action("Register","User")">Đăng ký ngay</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ============= JAVASCRIPT ============= -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const pwdInput = document.getElementById("MatKhau");
        const toggleBtn = document.getElementById("btnTogglePassword");
        const iconEyeOpen = document.getElementById("iconEyeOpen");
        const iconEyeSlash = document.getElementById("iconEyeSlash");
        const loginForm = document.getElementById("loginForm");
        const googleForm = document.getElementById("googleForm");
        const btnLogin = document.getElementById("btnLogin");
        const btnGoogle = document.getElementById("btnGoogleLogin");

        // Ẩn / hiện mật khẩu + đổi giữa mắt / mắt gạch
        if (toggleBtn && pwdInput && iconEyeOpen && iconEyeSlash) {
            toggleBtn.addEventListener("click", function () {
                const isHidden = pwdInput.type === "password";
                pwdInput.type = isHidden ? "text" : "password";

                if (isHidden) {
                    iconEyeOpen.classList.add("hidden");
                    iconEyeSlash.classList.remove("hidden");
                } else {
                    iconEyeSlash.classList.add("hidden");
                    iconEyeOpen.classList.remove("hidden");
                }
            });
        }

        // Chống double-submit
        if (loginForm && btnLogin) {
            loginForm.addEventListener("submit", function () {
                btnLogin.disabled = true;
            });
        }

        if (googleForm && btnGoogle) {
            googleForm.addEventListener("submit", function () {
                btnGoogle.disabled = true;
            });
        }
    });
</script>

<script src="https://www.google.com/recaptcha/api.js" async defer></script>
