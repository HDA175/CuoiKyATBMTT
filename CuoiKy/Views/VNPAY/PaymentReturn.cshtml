@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Kết quả thanh toán VNPay - EvolStore</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f5f5f5;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .payment-result {
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            text-align: center;
            max-width: 500px;
            width: 100%;
        }

        .success {
            color: #27ae60;
            border-left: 4px solid #27ae60;
        }

        .error {
            color: #e74c3c;
            border-left: 4px solid #e74c3c;
        }

        .icon {
            font-size: 48px;
            margin-bottom: 20px;
        }

        h1 {
            margin-bottom: 20px;
            font-size: 24px;
        }

        .details {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 8px;
            margin: 20px 0;
            text-align: left;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            padding: 5px 0;
        }

        .detail-label {
            font-weight: 600;
            color: #555;
        }

        .detail-value {
            color: #333;
        }

        .actions {
            margin-top: 30px;
        }

        .btn {
            display: inline-block;
            padding: 12px 24px;
            margin: 0 10px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background: #3498db;
            color: white;
        }

        .btn-secondary {
            background: #95a5a6;
            color: white;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body>
    <div class="payment-result @(ViewBag.Success == true ? "success" : "error")">
        <div class="icon">
            @if (ViewBag.Success == true)
            {
                <i class="fas fa-check-circle"></i>
            }
            else
            {
                <i class="fas fa-times-circle"></i>
            }
        </div>

        <h1>@ViewBag.Message</h1>

        @if (ViewBag.Success == true)
        {
            <div class="details">
                <div class="detail-row">
                    <span class="detail-label">Mã đơn hàng:</span>
                    <span class="detail-value">@ViewBag.OrderId</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Số tiền:</span>
                    <span class="detail-value">@String.Format("{0:n0}", ViewBag.Amount) ₫</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Mã giao dịch:</span>
                    <span class="detail-value">@ViewBag.TransactionNo</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Ngân hàng:</span>
                    <span class="detail-value">@ViewBag.BankCode</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Thời gian:</span>
                    <span class="detail-value">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>

            <p>Cảm ơn bạn đã mua hàng tại EvolStore! Đơn hàng của bạn đã được xác nhận.</p>
        }

        <div class="actions">
            @if (ViewBag.Success == true)
            {
                <a href="@Url.Action("Index", "EvolStore")" class="btn btn-primary">
                    <i class="fas fa-home"></i> Về trang chủ
                </a>
                <a href="@Url.Action("CuaHang", "EvolStore")" class="btn btn-secondary">
                    <i class="fas fa-shopping-bag"></i> Tiếp tục mua sắm
                </a>
            }
            else
            {
                <a href="@Url.Action("Index", "Checkout")" class="btn btn-primary">
                    <i class="fas fa-arrow-left"></i> Quay lại thanh toán
                </a>
                <a href="@Url.Action("CuaHang", "EvolStore")" class="btn btn-secondary">
                    <i class="fas fa-store"></i> Về cửa hàng
                </a>
            }
        </div>
    </div>
</body>
</html>