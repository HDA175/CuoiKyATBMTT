﻿@{
    Layout = null;
    // Lấy Vai trò từ Session và khai báo biến isAdmin
    var userRole = Session["AdminRole"] as string;
    var isAdmin = userRole == "Admin";
    var isNhanVienKho = userRole == "NhanVienKho";
    var isNhanVien = userRole == "NhanVien";
    // Biến để gộp Admin và Nhân viên thường (những người có toàn quyền)
    var isFullAccessNhanVien = isAdmin || isNhanVien;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thống kê - EvolStore Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --primary: #3498db;
            --success: #2ecc71;
            --warning: #f39c12;
            --danger: #e74c3c;
            --info: #9b59b6;
            --dark: #2c3e50;
            --light: #ecf0f1;
        }

        body {
            background: #f5f6fa;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            background: var(--dark);
            color: white;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
        }

        .logo {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid #34495e;
        }

            .logo h2 {
                color: white;
                font-size: 1.5rem;
            }

        .nav-links {
            padding: 20px 0;
        }

            .nav-links a {
                display: flex;
                align-items: center;
                padding: 15px 25px;
                color: #bdc3c7;
                text-decoration: none;
                transition: all 0.3s;
            }

                .nav-links a i {
                    margin-right: 10px;
                    width: 20px;
                    text-align: center;
                }

                .nav-links a:hover,
                .nav-links a.active {
                    background: #34495e;
                    color: white;
                    border-left: 4px solid var(--primary);
                }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: 250px;
            padding: 20px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            border-bottom: 1px solid #ddd;
            margin-bottom: 30px;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            text-decoration: none;
            color: white;
            cursor: pointer;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .btn-primary {
            background: var(--primary);
        }

        .btn-outline-primary {
            background: transparent;
            border: 1px solid var(--primary);
            color: var(--primary);
        }

        .btn-success {
            background: var(--success);
        }

        .btn-danger {
            background: var(--danger);
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 20px;
            transition: transform 0.3s;
        }

            .stat-card:hover {
                transform: translateY(-5px);
            }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: white;
        }

        .icon-revenue {
            background: var(--primary);
        }

        .icon-orders {
            background: var(--success);
        }

        .icon-customers {
            background: var(--warning);
        }

        .icon-pending {
            background: var(--danger);
        }

        .icon-products {
            background: var(--info);
        }

        .icon-avg {
            background: #1abc9c;
        }

        .stat-info h3 {
            font-size: 1.8rem;
            margin-bottom: 5px;
            color: var(--dark);
        }

        .stat-info p {
            color: #7f8c8d;
            font-size: 14px;
        }

        /* Charts Section */
        .charts-container {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .chart-card, .top-products-card {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid var(--light);
        }

        .card-title {
            color: var(--dark);
            font-size: 1.2rem;
            font-weight: 600;
        }

        .chart-container {
            position: relative;
            height: 300px;
            width: 100%;
        }

        /* Additional Stats Grid */
        .additional-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .mini-stat-card {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
            text-align: center;
        }

        .mini-stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: white;
            margin: 0 auto 10px;
        }

        .mini-stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--dark);
            margin-bottom: 5px;
        }

        .mini-stat-label {
            color: #7f8c8d;
            font-size: 12px;
        }

        /* Top Products */
        .product-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
        }

            .product-item:last-child {
                border-bottom: none;
            }

        .product-info {
            flex: 1;
        }

        .product-name {
            font-weight: 600;
            margin-bottom: 5px;
        }

        .product-stats {
            font-size: 0.9rem;
            color: #666;
        }

        .product-rank {
            background: var(--primary);
            color: white;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 0.9rem;
        }

        /* Recent Orders - COMPACT VERSION */
        .recent-orders {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }

        .compact-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

            .compact-table th, .compact-table td {
                padding: 10px 8px;
                text-align: left;
                border-bottom: 1px solid #eee;
            }

            .compact-table th {
                background: #f8f9fa;
                font-weight: 600;
                color: var(--dark);
                font-size: 12px;
            }

        .badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .badge-success {
            background: #d4edda;
            color: #155724;
        }

        .badge-warning {
            background: #fff3cd;
            color: #856404;
        }

        .badge-danger {
            background: #f8d7da;
            color: #721c24;
        }

        .badge-primary {
            background: #cce7ff;
            color: #004085;
        }

        .no-data {
            text-align: center;
            padding: 40px;
            color: #666;
        }

            .no-data i {
                font-size: 3rem;
                margin-bottom: 15px;
                color: #ddd;
            }

        /* Status Overview */
        .status-overview {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
        }

        .status-item {
            background: white;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.1);
            text-align: center;
        }

        .status-count {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 5px;
        }

        .status-label {
            font-size: 12px;
            color: #7f8c8d;
        }

        /* Responsive - ĐÃ SỬA LỖI */
        @@media (max-width: 1200px) {
            .charts-container {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 768px) {
            .main-content {
                margin-left: 0;
            }

            .sidebar {
                transform: translateX(-100%);
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .additional-stats {
                grid-template-columns: repeat(2, 1fr);
            }

            .status-overview {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 480px) {
            .additional-stats {
                grid-template-columns: 1fr;
            }

            .status-overview {
                grid-template-columns: 1fr;
            }

            .header {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="logo">
            <h2><i class="fas fa-store"></i> EvolStore Admin</h2>
        </div>

        <ul class="sidebar-menu nav-links">
            <li>
                <a href="@Url.Action("Dashboard")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Dashboard" ? "active" : "")">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            @if (isAdmin || isNhanVienKho)
            {
                <li>
                    <a href="@Url.Action("WarehouseManager")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "WarehouseManager" ? "active" : "")">
                        <i class="fas fa-warehouse"></i>
                        <span>Quản lý Kho</span>
                    </a>
                </li>
            }
            @if (isFullAccessNhanVien)
            {
                <li>
                    <a href="@Url.Action("Reports")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Reports" || ViewContext.RouteData.Values["Action"].ToString() == "RevenueByDate" ? "active" : "")">
                        <i class="fas fa-chart-line"></i>
                        <span>Thống kê & Báo cáo</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("RevenueByDate")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "RevenueByDate" ? "active" : "")">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Doanh thu theo ngày</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Orders")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Orders" || ViewContext.RouteData.Values["Action"].ToString() == "OrderDetails" ? "active" : "")">
                        <i class="fas fa-shopping-cart"></i>
                        <span>Quản lý Đơn hàng</span>
                    </a>
                </li>
            }

            <li>
                <a href="@Url.Action("Products")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Products" || ViewContext.RouteData.Values["Action"].ToString() == "AddProduct" || ViewContext.RouteData.Values["Action"].ToString() == "EditProduct" ? "active" : "")">
                    <i class="fas fa-box-open"></i>
                    <span>Quản lý Sản phẩm</span>
                </a>
            </li>

            @if (isFullAccessNhanVien)
            {
                <li>
                    <a href="@Url.Action("Customers")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Customers" || ViewContext.RouteData.Values["Action"].ToString() == "AddCustomer" || ViewContext.RouteData.Values["Action"].ToString() == "EditCustomer" ? "active" : "")">
                        <i class="fas fa-users"></i>
                        <span>Quản lý Khách hàng</span>
                    </a>
                </li>
            }

            @if (isAdmin)
            {
                <li>
                    <a href="@Url.Action("Employees")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Employees" || ViewContext.RouteData.Values["Action"].ToString() == "AddEmployee" || ViewContext.RouteData.Values["Action"].ToString() == "EditEmployee" ? "active" : "")">
                        <i class="fas fa-user-tie"></i>
                        <span>Quản lý Nhân viên</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Accounts")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Accounts" || ViewContext.RouteData.Values["Action"].ToString() == "AddAccount" || ViewContext.RouteData.Values["Action"].ToString() == "EditAccount" ? "active" : "")">
                        <i class="fas fa-user-lock"></i>
                        <span>Quản lý Tài khoản</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Sales")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Sales" ? "active" : "")">
                        <i class="fas fa-tags"></i>
                        <span>Quản lý Giảm giá</span>
                    </a>
                </li>
            }
            <li style="margin-top: auto;">
                <a href="@Url.Action("Logout")" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Đăng xuất</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="header">
            <h1>Thống kê & Báo cáo</h1>
            <div class="user-info">
                <span>Xin chào, <strong>@Session["AdminUsername"]</strong></span>
                <a href="@Url.Action("Logout")" class="btn btn-danger">
                    <i class="fas fa-sign-out-alt"></i> Đăng xuất
                </a>
            </div>
        </div>

        <!-- Thống kê tổng quan -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon icon-revenue">
                    <i class="fas fa-money-bill-wave"></i>
                </div>
                <div class="stat-info">
                    <h3>@((ViewBag.TongDoanhThu ?? 0).ToString("N0")) ₫</h3>
                    <p>Tổng doanh thu</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon icon-orders">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div class="stat-info">
                    <h3>@(ViewBag.TongDonHang ?? 0)</h3>
                    <p>Tổng đơn hàng</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon icon-customers">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3>@(ViewBag.TongKhachHang ?? 0)</h3>
                    <p>Khách hàng</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon icon-pending">
                    <i class="fas fa-clock"></i>
                </div>
                <div class="stat-info">
                    <h3>@(ViewBag.DonHangChoXuLy ?? 0)</h3>
                    <p>Đơn chờ xử lý</p>
                </div>
            </div>
        </div>

        <!-- Thống kê phụ -->
        <div class="additional-stats">
            <div class="mini-stat-card">
                <div class="mini-stat-icon icon-products" style="background: #9b59b6;">
                    <i class="fas fa-tshirt"></i>
                </div>
                <div class="mini-stat-value">@(ViewBag.TongSanPham ?? 0)</div>
                <div class="mini-stat-label">Sản phẩm</div>
            </div>

            <div class="mini-stat-card">
                <div class="mini-stat-icon icon-avg" style="background: #1abc9c;">
                    <i class="fas fa-calculator"></i>
                </div>
                <div class="mini-stat-value">
                    @if (ViewBag.GiaTriTrungBinh != null)
                    {
                        @(((decimal)ViewBag.GiaTriTrungBinh).ToString("N0")) <span>₫</span>
                    }
                    else
                    {
                        <span>0 ₫</span>
                    }
                </div>
                <div class="mini-stat-label">Giá trị TB/đơn</div>
            </div>

            <div class="mini-stat-card">
                <div class="mini-stat-icon" style="background: #e67e22;">
                    <i class="fas fa-star"></i>
                </div>
                <div class="mini-stat-value">
                    @if (ViewBag.DiemTrungBinh != null)
                    {
                        @(((double)ViewBag.DiemTrungBinh).ToString("0.0"))
                    }
                    else
                    {
                        <span>0.0</span>
                    }
                </div>
                <div class="mini-stat-label">Đánh giá TB</div>
            </div>

            <div class="mini-stat-card">
                <div class="mini-stat-icon" style="background: #34495e;">
                    <i class="fas fa-sync"></i>
                </div>
                <div class="mini-stat-value">@(ViewBag.DonHangDangGiao ?? 0)</div>
                <div class="mini-stat-label">Đang giao hàng</div>
            </div>
        </div>

        <!-- Trạng thái đơn hàng -->
        <div class="status-overview">
            <div class="status-item">
                <div class="status-count" style="color: #f39c12;">@(ViewBag.DonHangChoXuLy ?? 0)</div>
                <div class="status-label">Chờ xử lý</div>
            </div>
            <div class="status-item">
                <div class="status-count" style="color: #3498db;">@(ViewBag.DonHangDangGiao ?? 0)</div>
                <div class="status-label">Đang giao</div>
            </div>
            <div class="status-item">
                <div class="status-count" style="color: #2ecc71;">@(ViewBag.DonHangHoanThanh ?? 0)</div>
                <div class="status-label">Hoàn thành</div>
            </div>
            <div class="status-item">
                <div class="status-count" style="color: #e74c3c;">@(ViewBag.DonHangDaHuy ?? 0)</div>
                <div class="status-label">Đã hủy</div>
            </div>
        </div>

        <!-- Biểu đồ và Top sản phẩm -->
        <div class="charts-container">
            <div class="chart-card">
                <div class="card-header">
                    <div class="card-title">Doanh thu theo tháng - <span id="currentYear">@DateTime.Now.Year</span></div>
                    <div class="btn-group">
                        <button class="btn btn-outline-primary active">@DateTime.Now.Year</button>
                    </div>
                </div>
                <div class="chart-container">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>

            <div class="top-products-card">
                <div class="card-header">
                    <div class="card-title">Sản phẩm bán chạy</div>
                </div>
                <div id="topProductsList">
                    @if (ViewBag.TopProductNames != null && ((List<string>)ViewBag.TopProductNames).Count > 0)
                    {
                        for (int i = 0; i < ((List<string>)ViewBag.TopProductNames).Count; i++)
                        {
                            <div class="product-item">
                                <div class="product-info">
                                    <div class="product-name">@ViewBag.TopProductNames[i]</div>
                                    <div class="product-stats">
                                        Đã bán: @ViewBag.TopProductSales[i] |
                                        Doanh thu: @ViewBag.TopProductRevenues[i].ToString("N0") ₫
                                    </div>
                                </div>
                                <div class="product-rank">@(i + 1)</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="no-data">
                            <i class="fas fa-chart-bar"></i>
                            <p>Không có dữ liệu sản phẩm</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Đơn hàng gần đây - COMPACT VERSION -->
        <div class="recent-orders">
            <div class="card-header">
                <div class="card-title">Đơn hàng gần đây</div>
                <a href="@Url.Action("Orders")" class="btn btn-primary">
                    <i class="fas fa-eye"></i> Xem tất cả
                </a>
            </div>
            <div class="table-responsive">
                <table class="compact-table">
                    <thead>
                        <tr>
                            <th>Mã ĐH</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th>Số tiền</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.DonHangGanDay != null && ((List<CuoiKy.Models.DonHang>)ViewBag.DonHangGanDay).Count > 0)
                        {
                            foreach (var order in ViewBag.DonHangGanDay)
                            {
                                decimal total = 0;
                                foreach (var item in order.ChiTietDonHangs)
                                {
                                    total += (item.SoLuong ?? 0) * (item.DonGia ?? 0);
                                }
                                total += order.PhiGiaoHang ?? 0;

                                <tr>
                                    <td>#@order.MaDH</td>
                                    <td>@(order.KhachHang?.HoTen ?? "Khách hàng")</td>
                                    <td>
                                        @try
                                        {
                                            @order.NgayDat.ToString("dd/MM/yyyy")
                                        }
                                        catch
                                        {
                                            <span>N/A</span>
                                        }
                                    </td>
                                    <td>@total.ToString("N0") ₫</td>
                                    <td>
                                        @{
                                            var badgeClass = "badge-warning";
                                            if (order.TrangThai == "Hoàn thành")
                                            {
                                                badgeClass = "badge-success";
                                            }
                                            else if (order.TrangThai == "Đã hủy")
                                            {
                                                badgeClass = "badge-danger";
                                            }
                                            else if (order.TrangThai == "Đang giao")
                                            {
                                                badgeClass = "badge-primary";
                                            }
                                        }
                                        <span class="badge @badgeClass">@order.TrangThai</span>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("OrderDetails", new { id = order.MaDH })" class="btn btn-primary" style="padding: 4px 8px; font-size: 12px;">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="no-data">
                                    <i class="fas fa-shopping-cart"></i>
                                    <p>Không có đơn hàng gần đây</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Dữ liệu doanh thu từ controller
            var monthlyRevenue = @Html.Raw(Json.Encode(ViewBag.MonthlyRevenue ?? new decimal[12]));
            var currentYear = @DateTime.Now.Year;

            // Biểu đồ doanh thu
            var revenueChartCanvas = document.getElementById('revenueChart');
            if (revenueChartCanvas) {
                var hasData = monthlyRevenue.some(function(value) {
                    return value > 0;
                });

                if (hasData) {
                    var revenueChart = new Chart(revenueChartCanvas, {
                        type: 'bar',
                        data: {
                            labels: ['Th1', 'Th2', 'Th3', 'Th4', 'Th5', 'Th6', 'Th7', 'Th8', 'Th9', 'Th10', 'Th11', 'Th12'],
                            datasets: [{
                                label: 'Doanh thu (VND)',
                                data: monthlyRevenue,
                                backgroundColor: 'rgba(52, 152, 219, 0.7)',
                                borderColor: '#3498db',
                                borderWidth: 2,
                                borderRadius: 5
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    display: true,
                                    position: 'top'
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            return 'Doanh thu: ' + context.parsed.y.toLocaleString('vi-VN') + ' ₫';
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    grid: {
                                        drawBorder: false
                                    },
                                    ticks: {
                                        callback: function(value) {
                                            if (value >= 1000000) {
                                                return (value / 1000000).toFixed(1) + 'M ₫';
                                            } else if (value >= 1000) {
                                                return (value / 1000).toFixed(0) + 'K ₫';
                                            }
                                            return value.toLocaleString('vi-VN') + ' ₫';
                                        }
                                    }
                                },
                                x: {
                                    grid: {
                                        display: false
                                    }
                                }
                            }
                        }
                    });
                } else {
                    revenueChartCanvas.innerHTML = '<div class="no-data"><i class="fas fa-chart-line"></i><p>Không có dữ liệu doanh thu cho năm ' + currentYear + '</p></div>';
                }
            }
        });
    </script>
</body>
</html>