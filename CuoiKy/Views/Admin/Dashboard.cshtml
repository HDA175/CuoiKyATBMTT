@{
    Layout = null;
    // Lấy Vai trò từ Session và khai báo biến isAdmin
    var userRole = Session["AdminRole"] as string;
    var isAdmin = userRole == "Admin";
    var isNhanVienKho = userRole == "NhanVienKho";
    var isNhanVien = userRole == "NhanVien";
    // Biến để gộp Admin và Nhân viên thường (những người có toàn quyền)
    var isFullAccessNhanVien = isAdmin || isNhanVien;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - EvolStore Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --primary: #3498db;
            --success: #2ecc71;
            --warning: #f39c12;
            --danger: #e74c3c;
            --dark: #2c3e50;
            --light: #ecf0f1;
        }

        body {
            background: #f5f6fa;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            background: var(--dark);
            color: white;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
        }

        .logo {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid #34495e;
        }

            .logo h2 {
                color: white;
                font-size: 1.5rem;
            }

        .nav-links {
            padding: 20px 0;
        }

            .nav-links a {
                display: flex;
                align-items: center;
                padding: 15px 25px;
                color: #bdc3c7;
                text-decoration: none;
                transition: all 0.3s;
            }

                .nav-links a:hover,
                .nav-links a.active {
                    background: #34495e;
                    color: white;
                    border-left: 4px solid var(--primary);
                }

                .nav-links a i {
                    margin-right: 10px;
                    width: 20px;
                    text-align: center;
                }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: 250px;
            padding: 20px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            border-bottom: 1px solid #ddd;
            margin-bottom: 30px;
        }

            .header h1 {
                color: var(--dark);
            }

        .user-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .btn-logout {
            padding: 8px 15px;
            background: var(--danger);
            color: white;
            text-decoration: none;
            border-radius: 5px;
            font-size: 14px;
        }

            .btn-logout:hover {
                background: #c0392b;
            }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: white;
        }

        .icon-products {
            background: var(--primary);
        }

        .icon-orders {
            background: var(--success);
        }

        .icon-customers {
            background: var(--warning);
        }

        .icon-employees {
            background: var(--danger);
        }

        .stat-info h3 {
            font-size: 2rem;
            margin-bottom: 5px;
            color: var(--dark);
        }

        .stat-info p {
            color: #7f8c8d;
            font-size: 14px;
        }

        /* Quick Actions */
        .quick-actions {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }

            .quick-actions h2 {
                margin-bottom: 20px;
                color: var(--dark);
            }

        .action-buttons {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
        }

        .btn-action {
            padding: 15px;
            background: var(--light);
            border: none;
            border-radius: 8px;
            text-align: center;
            text-decoration: none;
            color: var(--dark);
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

            .btn-action:hover {
                background: var(--primary);
                color: white;
                transform: translateY(-2px);
            };''

            .btn-action i {
                font-size: 24px;
            }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="logo">
            <h2><i class="fas fa-store"></i> EvolStore Admin</h2>
        </div>

        <ul class="sidebar-menu nav-links">
            <li>
                <a href="@Url.Action("Dashboard")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Dashboard" ? "active" : "")">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
            </li>
            @if (isAdmin || isNhanVienKho)
            {
                <li>
                    <a href="@Url.Action("WarehouseManager")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "WarehouseManager" ? "active" : "")">
                        <i class="fas fa-warehouse"></i>
                        <span>Quản lý Kho</span>
                    </a>
                </li>
            }
            @if (isFullAccessNhanVien)
            {
                <li>
                    <a href="@Url.Action("Reports")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Reports" || ViewContext.RouteData.Values["Action"].ToString() == "RevenueByDate" ? "active" : "")">
                        <i class="fas fa-chart-line"></i>
                        <span>Thống kê & Báo cáo</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("RevenueByDate")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "RevenueByDate" ? "active" : "")">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Doanh thu theo ngày</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Orders")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Orders" || ViewContext.RouteData.Values["Action"].ToString() == "OrderDetails" ? "active" : "")">
                        <i class="fas fa-shopping-cart"></i>
                        <span>Quản lý Đơn hàng</span>
                    </a>
                </li>
            }

            <li>
                <a href="@Url.Action("Products")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Products" || ViewContext.RouteData.Values["Action"].ToString() == "AddProduct" || ViewContext.RouteData.Values["Action"].ToString() == "EditProduct" ? "active" : "")">
                    <i class="fas fa-box-open"></i>
                    <span>Quản lý Sản phẩm</span>
                </a>
            </li>

            @if (isFullAccessNhanVien)
            {
                <li>
                    <a href="@Url.Action("Customers")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Customers" || ViewContext.RouteData.Values["Action"].ToString() == "AddCustomer" || ViewContext.RouteData.Values["Action"].ToString() == "EditCustomer" ? "active" : "")">
                        <i class="fas fa-users"></i>
                        <span>Quản lý Khách hàng</span>
                    </a>
                </li>
            }

            @if (isAdmin)
            {
                <li>
                    <a href="@Url.Action("Employees")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Employees" || ViewContext.RouteData.Values["Action"].ToString() == "AddEmployee" || ViewContext.RouteData.Values["Action"].ToString() == "EditEmployee" ? "active" : "")">
                        <i class="fas fa-user-tie"></i>
                        <span>Quản lý Nhân viên</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Accounts")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Accounts" || ViewContext.RouteData.Values["Action"].ToString() == "AddAccount" || ViewContext.RouteData.Values["Action"].ToString() == "EditAccount" ? "active" : "")">
                        <i class="fas fa-user-lock"></i>
                        <span>Quản lý Tài khoản</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Sales")" class="@(ViewContext.RouteData.Values["Action"].ToString() == "Sales" ? "active" : "")">
                        <i class="fas fa-tags"></i>
                        <span>Quản lý Giảm giá</span>
                    </a>
                </li>
            }
            <li style="margin-top: auto;">
                <a href="@Url.Action("Logout")" class="logout-btn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Đăng xuất</span>
                </a>
            </li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="header">
            <h1>Dashboard</h1>
            <div class="user-info">
                <span>Xin chào, <strong>@Session["AdminUsername"]</strong></span>
                <a href="@Url.Action("Logout")" class="btn-logout">
                    <i class="fas fa-sign-out-alt"></i> Đăng xuất
                </a>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon icon-products">
                    <i class="fas fa-tshirt"></i>
                </div>
                <div class="stat-info">
                    <h3>@ViewBag.TongSanPham</h3>
                    <p>Tổng sản phẩm</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon icon-orders">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div class="stat-info">
                    <h3>@ViewBag.TongDonHang</h3>
                    <p>Tổng đơn hàng</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon icon-customers">
                    <i class="fas fa-users"></i>
                </div>
                <div class="stat-info">
                    <h3>@ViewBag.TongKhachHang</h3>
                    <p>Khách hàng</p>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-icon icon-employees">
                    <i class="fas fa-user-tie"></i>
                </div>
                <div class="stat-info">
                    <h3>@ViewBag.TongNhanVien</h3>
                    <p>Nhân viên</p>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="quick-actions">
            <h2>Thao tác nhanh</h2>
            <div class="action-buttons">
                <a href="@Url.Action("Products")" class="btn-action">
                    <i class="fas fa-plus"></i>
                    <span>Thêm sản phẩm</span>
                </a>
                <a href="@Url.Action("Orders")" class="btn-action">
                    <i class="fas fa-eye"></i>
                    <span>Xem đơn hàng</span>
                </a>
                <a href="@Url.Action("Customers")" class="btn-action">
                    <i class="fas fa-user-friends"></i>
                    <span>Quản lý khách hàng</span>
                </a>
                <a href="@Url.Action("Dashboard")" class="btn-action">
                    <i class="fas fa-chart-bar"></i>
                    <span>Xem báo cáo</span>
                </a>
            </div>
        </div>
    </div>
</body>
</html>